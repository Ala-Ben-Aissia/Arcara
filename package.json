{
  "name": "arcara",
  "version": "0.1.2",
  "description": "Zero-dependency Node.js HTTP framework. Type-safe routing, nested routers, and scoped error handling — built with modern TypeScript.",
  "keywords": [
    "node",
    "http",
    "framework",
    "typescript",
    "router",
    "zero-dependency",
    "backend",
    "server",
    "middleware",
    "esm"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm run build && npm publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Ala Ben Aissia",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ala-Ben-Aissia/arcara.git"
  },
  "bugs": {
    "url": "https://github.com/Ala-Ben-Aissia/arcara/issues"
  },
  "homepage": "https://github.com/Ala-Ben-Aissia/arcara#readme"
}
