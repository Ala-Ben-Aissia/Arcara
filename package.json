{
  "name": "arcara",
  "version": "0.1.0",
  "description": "A TypeScript-native, zero-dependency Node.js HTTP framework",
  "author": "Aloulou <alabenaissia@users.noreply.github.com>",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "http",
    "framework",
    "router",
    "middleware",
    "typescript",
    "node",
    "zero-dependency",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ala-Ben-Aissia/arcara.git"
  },
  "bugs": {
    "url": "https://github.com/Ala-Ben-Aissia/arcara/issues"
  },
  "homepage": "https://github.com/Ala-Ben-Aissia/arcara#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build:js": "tsup --config tsup.config.ts",
    "build:dts": "tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "build:dcts": "node -e \"const fs=require('fs');const s=fs.readFileSync('dist/index.d.ts','utf8');fs.writeFileSync('dist/index.d.cts',s);\"",
    "build": "pnpm build:js && pnpm build:dts && pnpm build:dcts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "tsx --test src/tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm run test"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "6.0.2",
    "@types/node": "^25.5.2"
  },
  "dependencies": {
    "@types/node": "^25.5.2"
  }
}
