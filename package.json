{
  "name": "arcara",
  "version": "0.1.7",
  "description": "A TypeScript-native, zero-dependency Node.js HTTP framework",
  "author": "Ala Ben Aissia alabenaissia@outlook.com",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "http",
    "framework",
    "router",
    "middleware",
    "typescript",
    "node",
    "zero-dependency",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ala-Ben-Aissia/arcara.git"
  },
  "bugs": {
    "url": "https://github.com/Ala-Ben-Aissia/arcara/issues"
  },
  "homepage": "https://github.com/Ala-Ben-Aissia/arcara#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "tsx --test src/tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {},
  "dependencies": {}
}
