{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/tests/",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/playground/"
  ]
}
